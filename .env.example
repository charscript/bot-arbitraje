# ============================================================
#  Configuración del Bot de Arbitraje Híbrido
#  Copia este archivo a .env y completa tus valores reales.
# ============================================================

# ── Telegram ──────────────────────────────────────────────
# Obtén el token con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=TU_TOKEN_AQUI
# Obtén tu Chat ID con @userinfobot
TELEGRAM_CHAT_ID=TU_CHAT_ID_AQUI

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Exchange ─────────────────────────────────────────────
EXCHANGE_ID=bybit
# Pares del triángulo (separados por coma, sin espacios)
PARES=BTC/USDT,ETH/BTC,ETH/USDT

# ── Risk Engine ──────────────────────────────────────────
CAPITAL_MAX_USDT=500
MIN_SPREAD_PCT=0.05
MAX_ERRORES_CONSECUTIVOS=5
